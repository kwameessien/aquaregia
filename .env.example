# Local only — copy to `.env.local` at the repo root (gitignored).
# Get Project ID: https://www.sanity.io/manage → your project → Project ID

NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Optional: draft/private content (server-only; add in Vercel for preview if needed)
# SANITY_API_READ_TOKEN=

# --- Vercel (Production / Preview) ---
# Project → Settings → Environment Variables → add the same keys as above:
#   NEXT_PUBLIC_SANITY_PROJECT_ID
#   NEXT_PUBLIC_SANITY_DATASET   (e.g. production)
# Optional: SANITY_API_READ_TOKEN (mark Sensitive; not NEXT_PUBLIC_*)
