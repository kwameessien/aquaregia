# Sanity — https://www.sanity.io/manage → Project ID
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Optional: draft/private content (server-only; Vercel preview)
# SANITY_API_READ_TOKEN=

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Rituals book (or default product): Dashboard → Products → Price ID like price_...
STRIPE_PRICE_ID=price_...

# Dashboard → Developers → Webhooks → endpoint signing secret (whsec_...)
STRIPE_WEBHOOK_SECRET=whsec_...

# Client: set to true to use Stripe Checkout for “Add to cart” on /rituals-book
NEXT_PUBLIC_STRIPE_CHECKOUT=true

# Used when building checkout redirect URLs without a browser Origin header
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional — only if Stripe Tax is configured for the account
# STRIPE_CHECKOUT_AUTOMATIC_TAX=true
